#include<stdio.h>

int main()
{
    int a[10], i, j;

    printf("Enter 10 IDs:\n");
    for(i=0; i<10; i++)
        scanf("%d", &a[i]);

    for(i=0; i<10; i++)
    {
        for(j=0; j<i; j++)
        {
            if(a[i] == a[j])
            {
                a[i] = -1;
                break;
            }
        }
    }

    printf("Updated array:\n");
    for(i=0; i<10; i++)
        printf("%d ", a[i]);

    return 0;
}

