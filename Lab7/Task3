#include<stdio.h>

int main()
{
    int pass[10], fail[10];
    int i=0,j=0,k,m;
    int sum1=0, sum2=0;
    float avg1, avg2;

    printf("Enter quiz marks (-1 to stop):\n");

    while(1)
    {
        scanf("%d",&m);

        if(m==-1)
            break;

        if(m>=5 && m<=10)
        {
            pass[i]=m;
            sum1=sum1+m;
            i++;
        }
        else if(m>=0 && m<5)
        {
            fail[j]=m;
            sum2=sum2+m;
            j++;
        }
    }

    printf("Pass marks:\n");
    for(k=0;k<i;k++)
        printf("%d ",pass[k]);

    printf("\nFail marks:\n");
    for(k=0;k<j;k++)
        printf("%d ",fail[k]);

    if(i>0)
        avg1=(float)sum1/i;
    else
        avg1=0;

    if(j>0)
        avg2=(float)sum2/j;
    else
        avg2=0;

    printf("\nAverage of pass marks = %.2f",avg1);
    printf("\nAverage of fail marks = %.2f",avg2);

    return 0;
}

